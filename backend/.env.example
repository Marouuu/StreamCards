# Server
PORT=5000
NODE_ENV=development

# Database (local dev — use individual vars)
DB_USER=postgres
DB_HOST=localhost
DB_NAME=streamcards
DB_PASSWORD=
DB_PORT=5432

# Database (production — use connection string from Supabase)
# DATABASE_URL=postgresql://postgres.xxxx:password@aws-0-region.pooler.supabase.com:6543/postgres

# Twitch OAuth
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
TWITCH_REDIRECT_URI=http://localhost:5000/api/auth/twitch/callback
FRONTEND_URL=http://localhost:5173

# JWT Secret (generate a random 64+ char string for production)
JWT_SECRET=

# Twitch EventSub (for Channel Points integration)
TWITCH_EVENTSUB_SECRET=
TWITCH_WEBHOOK_CALLBACK_URL=http://localhost:5000/api/twitch/eventsub/callback

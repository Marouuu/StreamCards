# Server
PORT=5000
NODE_ENV=development

# Database
DB_USER=postgres
DB_HOST=localhost
DB_NAME=streamcards
DB_PASSWORD=your_password_here
DB_PORT=5432

# Twitch OAuth
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret
TWITCH_REDIRECT_URI=http://localhost:5000/api/auth/twitch/callback

# Frontend URL (for OAuth redirects)
FRONTEND_URL=http://localhost:5173

# JWT Secret (for session management)
JWT_SECRET=your_jwt_secret_key_here

# Stripe (Premium subscriptions)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_VIEWER_PRICE_ID=price_viewer_premium_id
STRIPE_STREAMER_PRICE_ID_SMALL=price_streamer_small_id
STRIPE_STREAMER_PRICE_ID_MEDIUM=price_streamer_medium_id
STRIPE_STREAMER_PRICE_ID_LARGE=price_streamer_large_id
STRIPE_STREAMER_PRICE_ID_ENTERPRISE=price_streamer_enterprise_id

